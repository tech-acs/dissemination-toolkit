{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "vendor/bin/testbench",
                "boost:mcp"
            ]
        },
        "codegraph": {
          "type": "local",
          "command": [
            "codegraph",
            "serve",
            "--mcp"
          ],
          "enabled": true
        }
    }
}